  @promise @rename("getImageInfo")
  GetImageInfoReturnsPromise(index: Optional<i32>): Optional<ImageInfo>;

  GetImageInfoSync(index: Optional<i32>): Optional<ImageInfo>;

  @async @rename("createPixelMap")
  CreatePixelMapWithOptionsCallback(options: DecodingOptions): Optional<PixelMap>;

  @async @rename("createPixelMap")
  CreatePixelMapWithCallback(): Optional<PixelMap>;

  @promise @rename("createPixelMap")
  CreatePixelMapReturnsPromise(options: Optional<DecodingOptions>): Optional<PixelMap>;

  CreatePixelMapSync(options: Optional<DecodingOptions>): Optional<PixelMap>;

  @promise @rename("createPixelMapUsingAllocator")
  CreatePixelMapUsingAllocatorPromise(options: Optional<DecodingOptions>, allocatorType: Optional<AllocatorType>): Optional<PixelMap>;

  CreatePixelMapUsingAllocatorSync(options: Optional<DecodingOptions>, allocatorType: Optional<AllocatorType>): Optional<PixelMap>;

  @async @rename("createPixelMapList")
  CreatePixelMapListSync(): Array<PixelMap>;

  @async @rename("createPixelMapList")
  CreatePixelMapListSyncWithOptions(options: DecodingOptions): Array<PixelMap>;

  @promise @rename("createPixelMapList")
  CreatePixelMapListSyncWithOptionalOptions(options: Optional<DecodingOptions>): Array<PixelMap>;

  @async @rename("getDelayTimeList")
  GetDelayTimeListAsync(): Array<i32>;

  @promise @rename("getDelayTimeList")
  GetDelayTimeListPromise(): Array<i32>;

  GetDelayTimeListSync(): Array<i32>;

  @promise @rename("getDisposalTypeList")
  GetDisposalTypeListSync(): Array<i32>;

  @async @rename("getFrameCount")
  GetFrameCountAsync(): i32;

  @promise @rename("getFrameCount")
  GetFrameCountPromise(): i32;

  GetFrameCountSync(): i32;

  @promise @rename("getImageProperty")
  GetImagePropertyReturnsPromise(key: PropertyKey, options: Optional<ImagePropertyOptions>): String;

  @promise @rename("getImageProperties")
  GetImagePropertiesSync(key: Array<PropertyKey>): @record Map<String, PropertyValue>;

  GetImagePropertySync(key: PropertyKey): Optional<String>;

  @promise @rename("modifyImageProperty")
  ModifyImagePropertySync(key: PropertyKey, value: String): void;

  @promise @rename("modifyImageProperties")
  ModifyImagePropertiesSync(records: @record Map<String, PropertyValue>): void;

  @promise @rename("modifyImagePropertiesEnhanced")
  ModifyImagePropertiesEnhancedSync(records: @record Map<String, PropertyValue>): void;

  @promise @rename("modifyImageAllProperties")
  modifyImageAllPropertiesSync(records: @record Map<String, PropertyValue>): void;

  @async @rename("updateData")
  UpdateDataAsync(buf: @arraybuffer Array<u8>, isFinished: bool, offset: i32, length: i32): void;

  @promise @rename("updateData")
  UpdateDataPromise(buf: @arraybuffer Array<u8>, isFinished: bool, offset: i32, length: i32): void;

  UpdateDataSync(buf: @arraybuffer Array<u8>, isFinished: bool, offset: i32, length: i32): void;

  @async @rename("release")
  ReleaseAsync(): void;

  @promise @rename("release")
  ReleasePromise(): void;

  ReleaseSync(): void;

  @promise @rename("createPicture")
  CreatePictureSync(options: Optional<DecodingOptionsForPicture>): Optional<Picture>;

  @promise @rename("createPictureAtIndex")
  CreatePictureAtIndexSync(index: i32): Optional<Picture>;

  @promise @rename("createWideGamutSdrPixelMap")
  CreateWideGamutSdrPixelMapSync(): Optional<PixelMap>;

  @promise @rename("createThumbnail")
  CreateThumbnailSync(options: Optional<DecodingOptionsForThumbnail>): Optional<PixelMap>;

  @get GetSupportedFormats(): Array<String>;

  // @gen_promise("readXMPMetadata")
  // ReadXMPMetadataSync(): NullableXMPMetadata;

  // @gen_promise("writeXMPMetadata")
  // WriteXMPMetadataSync(xmpMetadata: XMPMetadata): void;

  ReadImageMetadataPackage(propertyKeys: Optional<Array<String>>, index: Optional<i32>): ImageMetadataPackage;
  ReadImageMetadataPackageByType(metadataTypes: Optional<Array<MetadataType>>, index: Optional<i32>): ImageMetadataPackage;
  WriteImageMetadataPackage(imageMetadataPackage: ImageMetadataPackage): void;

  @!sts_inject_into_interface("readImageMetadata(propertyKeys?: string[], index?: int): Promise<image.ImageMetadata>;")
  @!sts_inject_into_interface("readImageMetadataByType(metadataTypes?: image.MetadataType[], index?: int): Promise<image.ImageMetadata>;")
  @!sts_inject_into_interface("writeImageMetadata(imageMetadata: image.ImageMetadata): Promise<void>;")
  @!sts_inject_into_class("""
    readImageMetadata(propertyKeys?: string[], index?: int): Promise<image.ImageMetadata> {
      return new Promise<image.ImageMetadata>((resolve, reject): void => {
        let cb = (): image.ImageMetadata | Error => {
          let result: image.ImageMetadata | Error;
          try {
            let imageMetadataPackage = this.readImageMetadataPackage(propertyKeys, index);
            if (imageMetadataPackage.properties != undefined) {
              this.assembleImageMetadata(imageMetadataPackage.metadata, imageMetadataPackage.properties!);
            }
            result = imageMetadataPackage.metadata;
          } catch(e) {
            result = e as Error;
          }
          return result;
        };
        taskpool.execute(cb).then((ret: Any): void => {
          if (ret instanceof Error) {
            reject(ret);
          } else {
            resolve(ret as image.ImageMetadata);
          }
        });
      });
    }

    readImageMetadataByType(metadataTypes?: image.MetadataType[], index?: int): Promise<image.ImageMetadata> {
      return new Promise<image.ImageMetadata>((resolve, reject): void => {
        let cb = (): image.ImageMetadata | Error => {
          let result: image.ImageMetadata | Error;
          try {
            let imageMetadataPackage = this.readImageMetadataPackageByType(metadataTypes, index);
            if (imageMetadataPackage.properties != undefined) {
              this.assembleImageMetadata(imageMetadataPackage.metadata, imageMetadataPackage.properties!);
            }
            result = imageMetadataPackage.metadata;
          } catch(e) {
            result = e as Error;
          }
          return result;
        };
        taskpool.execute(cb).then((ret: Any): void => {
          if (ret instanceof Error) {
            reject(ret);
          } else {
            resolve(ret as image.ImageMetadata);
          }
        });
      });
    }

    writeImageMetadata(imageMetadata: image.ImageMetadata): Promise<void> {
      return new Promise<void>((resolve, reject): void => {
        let cb = (): undefined | Error => {
          let result: undefined | Error;
          try {
            let properties = this.extractImageMetadata(imageMetadata);
            let imageMetadataPackage: image.ImageMetadataPackage = {
              metadata: imageMetadata,
              properties: properties
            };
            this.writeImageMetadataPackage(imageMetadataPackage);
            result = undefined;
          } catch(e) {
            result = e as Error;
          }
          return result;
        };
        taskpool.execute(cb).then((ret: Any): void => {
          if (ret instanceof Error) {
            reject(ret);
          } else {
            resolve(ret as undefined);
          }
        });
      });
    }

    private assembleImageMetadata(imageMetadata: image.ImageMetadata, metadataValues: Array<image.MetadataValue>): void {
      for (const metadataValue of metadataValues) {
        let status = false;
        switch (metadataValue.metadataType) {
          case image.MetadataType.EXIF_METADATA: {
            const exifMetadata = imageMetadata.exifMetadata;
            if (exifMetadata == undefined) {
              console.info("[assembleImageMetadata] exifMetadata is undefined");
              break;
            }
            status = MetadataFieldHelper.setFieldViaReflection(exifMetadata, metadataValue.key, metadataValue.value);
            break;
          }
          case image.MetadataType.HW_MAKER_NOTE_METADATA:
            const makerNoteHuaweiMetadata = imageMetadata.makerNoteHuaweiMetadata;
            if (makerNoteHuaweiMetadata == undefined) {
              console.info("[assembleImageMetadata] makerNoteHuaweiMetadata is undefined");
              break;
            }
            status = MetadataFieldHelper.setFieldViaReflection(makerNoteHuaweiMetadata, metadataValue.key, metadataValue.value);
           break;
          case image.MetadataType.HEIFS_METADATA:
            const heifsMetadata = imageMetadata.heifsMetadata;
            if (heifsMetadata == undefined) {
              console.info("[assembleImageMetadata] heifsMetadata is undefined");
              break;
            }
            status = MetadataFieldHelper.setFieldViaReflection(heifsMetadata, metadataValue.key, metadataValue.value);
            break;
          case image.MetadataType.DNG_METADATA:
            const dngMetadata = imageMetadata.dngMetadata;
            if (dngMetadata == undefined) {
              console.info("[assembleImageMetadata] dngMetadata is undefined");
              break;
            }
            status = MetadataFieldHelper.setFieldViaReflection(dngMetadata, metadataValue.key, metadataValue.value);
            break;
          case image.MetadataType.WEBP_METADATA:
            const webPMetadata = imageMetadata.webPMetadata;
            if (webPMetadata == undefined) {
              console.info("[assembleImageMetadata] webPMetadata is undefined");
              break;
            }
            status = MetadataFieldHelper.setFieldViaReflection(webPMetadata, metadataValue.key, metadataValue.value);
            break;
          case image.MetadataType.AVIS_METADATA:
            const avisMetadata = imageMetadata.avisMetadata;
            if (avisMetadata == undefined) {
              console.info("[assembleImageMetadata] avisMetadata is undefined");
              break;
            }
            status = MetadataFieldHelper.setFieldViaReflection(avisMetadata, metadataValue.key, metadataValue.value);
            break;
          default:
            console.error(`[assembleImageMetadata] Unsupported metadata type: ${metadataValue.metadataType}`);
            break;
        }
        if (!status) {
            console.error(`[assembleImageMetadata] setField to object failed! ` +
              `metadataType: ${metadataValue.metadataType}, key: ${metadataValue.key}, value: ${metadataValue.value}`);
        }
      }
    }

    private extractImageMetadata(imageMetadata: image.ImageMetadata): Array<image.MetadataValue> | undefined {
      let metadataValues: image.MetadataValue[] = [];

      const appendFromObject = (metadataType: image.MetadataType, obj: Object): void => {
        const fieldsRecord: Record<string, Any> = MetadataFieldHelper.getAllFieldValues(obj);
        const entriesIter = fieldsRecord.entries();
        let entry = entriesIter.next();
        while (!entry.done) {
          if (entry.value == undefined) {
            entry = entriesIter.next();
            continue;
          }
          const key = entry.value![0];
          const value = entry.value![1];

          if (MetadataFieldHelper.isValidMetadataValue(value)) {
            metadataValues.push({
              metadataType: metadataType,
              key: key,
              value: value as image.MetadataValueType
            });
          }
          entry = entriesIter.next();
        }
      };

      const exifMetadata = imageMetadata.exifMetadata;
      if (exifMetadata != undefined) {
        appendFromObject(image.MetadataType.EXIF_METADATA, exifMetadata);
      }
      const makerNoteHuaweiMetadata = imageMetadata.makerNoteHuaweiMetadata;
      if (makerNoteHuaweiMetadata != undefined) {
        appendFromObject(image.MetadataType.HW_MAKER_NOTE_METADATA, makerNoteHuaweiMetadata);
      }

      return metadataValues.length > 0 ? metadataValues : undefined;
    }
  """)

  @promise CreateImageRawData(): ImageRawData;
}

interface ImagePacker {
  GetImplPtr(): i64;

  @promise @rename("packToData")
  PackImageSourceToDataSync(source: ImageSource, options: PackingOption): @arraybuffer Array<u8>;

  @promise @rename("packToData")
  PackPixelMapToDataSync(source: PixelMap, options: PackingOption): @arraybuffer Array<u8>;

  @promise @rename("packToDataFromPixelmapSequence")
  PackToDataFromPixelmapSequenceSync(pixelmapSequence: Array<PixelMap>, options: PackingOptionsForSequence): @arraybuffer Array<u8>;

  @async @rename("packToFile")
  PackImageSourceToFileAsync(source: ImageSource, fd: i32, options: PackingOption): void;

  @promise @rename("packToFile")
  PackImageSourceToFilePromise(source: ImageSource, fd: i32, options: PackingOption): void;

  PackImageSourceToFileSync(source: ImageSource, fd: i32, options: PackingOption): void;

  @async @rename("packToFile")
  PackPixelMapToFileAsync(source: PixelMap, fd: i32, options: PackingOption): void;

  @promise @rename("packToFile")
  PackPixelMapToFilePromise(source: PixelMap, fd: i32, options: PackingOption): void;

  PackPixelMapToFileSync(source: PixelMap, fd: i32, options: PackingOption): void;

  @promise @rename("packToFileFromPixelmapSequence")
  PackToFileFromPixelmapSequenceSync(pixelmapSequence: Array<PixelMap>, fd: i32, options: PackingOptionsForSequence): void;

  @promise @rename("packToFile")
  PackPictureToFileSync(picture: Picture, fd: i32, options: PackingOption): void;

  @promise @rename("packing")
  PackingPictureSync(picture: Picture, options: PackingOption): @arraybuffer Array<u8>;

  @async @rename("release")
  ReleaseAsync(): void;

  @promise @rename("release")
  ReleasePromise(): void;

  ReleaseSync(): void;

  @get GetSupportedFormats(): Array<String>;
}

interface Image {
  @get("clipRect") GetClipRect(): Region;
  GetImplPtr(): i64;

  @get("size") GetSize(): Size;
  @get("format") GetFormat(): i32;
  @get("timestamp") GetTimestamp(): i64;
  @get("colorSpace") GetColorSpace(): @sts_type("colorSpaceManager.ColorSpace") Opaque; 

  @async @rename("getComponent")
  GetComponentAsync(componentType: ComponentType): Component;

  @promise @rename("getComponent")
  GetComponentPromise(componentType: ComponentType): Component;

  GetComponentSync(componentType: ComponentType): Component;

  GetBufferData(): NullableImageBufferData;

  GetMetadata(key: HdrMetadataKey): NullableHdrMetadataValue;

  @async @rename("release")
  ReleaseAsync(): void;

  @promise @rename("release")
  ReleasePromise(): void;

  ReleaseSync(): void;
}

interface ImageReceiver {
  GetImplPtr(): i64;

  @get GetSize(): Size;
  @get GetCapacity(): i32;
  @get GetFormat(): ImageFormat;

  @async @rename("getReceivingSurfaceId")
  GetReceivingSurfaceIdAsync(): String;

  @promise @rename("getReceivingSurfaceId")
  GetReceivingSurfaceIdPromise(): String;

  GetReceivingSurfaceIdSync(): String;

  @async @rename("readLatestImage")
  ReadLatestImageAsync(): Image;

  @promise @rename("readLatestImage")
  ReadLatestImagePromise(): Image;

  ReadLatestImageSync(): Image;

  @async @rename("readNextImage")
  ReadNextImageAsync(): Image;

  @promise @rename("readNextImage")
  ReadNextImagePromise(): Image;

  ReadNextImageSync(): Image;

  OnImageArrival(callback: (err: @sts_type("BusinessError<void>") Opaque, data: @sts_type("undefined") Opaque)=> void): void;
  OffImageArrival(callback: Optional<(err: @sts_type("BusinessError<void>") Opaque, data: @sts_type("undefined") Opaque)=> void>): void;

  @async @rename("release")
  ReleaseAsync(): void;

  @promise @rename("release")
  ReleasePromise(): void;

  ReleaseSync(): void;
}

interface ImageCreator {
  GetImplPtr(): i64;

  @get("capacity") GetCapacity(): i32;
  @get("format") GetFormat(): ImageFormat;

  @async @rename("queueImage")
  QueueImageAsync(image: Image): void;

  @promise @rename("queueImage")
  QueueImagePromise(image: Image): void;

  QueueImageSync(image: Image): void;

  @async @rename("dequeueImage")
  DequeueImageAsync(): Image;

  @promise @rename("dequeueImage")
  DequeueImagePromise(): Image;

  DequeueImageSync(): Image;

  OnImageRelease(callback: (err: @sts_type("BusinessError<void>") Opaque, data: @sts_type("undefined") Opaque)=> void): void;
  OffImageRelease(callback: Optional<(err: @sts_type("BusinessError<void>") Opaque, data: @sts_type("undefined") Opaque)=> void>): void;

  @async @rename("release")
  ReleaseAsync(): void;

  @promise @rename("release")
  ReleasePromise(): void;

  ReleaseSync(): void;
}

