const XMP_BASIC: XMPNamespace = {
    uri: "http://ns.adobe.com/xap/1.0/",
    prefix: "xmp"
};

const XMP_RIGHTS: XMPNamespace = {
    uri: "http://ns.adobe.com/xap/1.0/rights/",
    prefix: "xmpRights"
};

const EXIF: XMPNamespace = {
    uri: "http://ns.adobe.com/exif/1.0/",
    prefix: "exif"
};

const DUBLIN_CORE: XMPNamespace = {
    uri: "http://purl.org/dc/elements/1.1/",
    prefix: "dc"
};

const TIFF: XMPNamespace = {
    uri: "http://ns.adobe.com/tiff/1.0/",
    prefix: "tiff"
};
""")

