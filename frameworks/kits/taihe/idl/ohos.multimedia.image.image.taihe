@!sts_inject("""
class MetadataFieldHelper {
  static deepCopyValue(value: Any): Any {
    if (value === undefined || value === null) {
      return value;
    }
    if (value instanceof ArrayBuffer) {
      return new Uint8Array(value).slice().buffer;
    }
    if (Array.isArray(value)) {
      return (value as Array<Any>).slice();
    }
    return value;
  }

  static copyDeclaredFields(src: Object, dst: Object): void {
    let currentClass: Class | undefined = Class.of(src);
    while (currentClass) {
      const fields: FixedArray<reflect.InstanceField> = currentClass.getInstanceFields();
      for (const field of fields) {
        const fieldName = field.getName();
        const fieldValue = field.getValue(src);
        if (fieldValue === undefined || fieldValue === null) {
          continue;
        }
        const copiedValue = MetadataFieldHelper.deepCopyValue(fieldValue);
        const dstClass = Class.of(dst);
        const dstField = dstClass.getInstanceField(fieldName);
        if (dstField) {
          dstField.setValue(dst, copiedValue);
        }
      }
      currentClass = currentClass.getSuper();
    }
  }

  static setFieldViaReflection(obj: Object, fieldName: string, value: Any): boolean {
    const clazz = Class.of(obj);
    const field = clazz.getInstanceField(fieldName);
    if (field) {
      field.setValue(obj, value);
      return true;
    }
    return false;
  }

  static getAllFieldValues(obj: Object): Record<string, Any> {
    const result: Record<string, Any> = {};
    let currentClass: Class | undefined = Class.of(obj);
    while (currentClass) {
      const fields: FixedArray<reflect.InstanceField> = currentClass.getInstanceFields();
      for (const field of fields) {
        result[field.getName()] = field.getValue(obj);
      }
      currentClass = currentClass.getSuper();
    }
    return result;
  }

  static isValidMetadataValue(value: Any): boolean {
    if (value === undefined || value === null) {
      return false;
    }

    if (value instanceof ArrayBuffer || value instanceof image.Orientation ||
        value instanceof image.XmageColorMode || value instanceof image.FocusMode) {
      return true;
    }

    const valueType = Type.of(value);
    if (valueType instanceof StringType || valueType instanceof BooleanType ||
      valueType instanceof IntType || valueType instanceof DoubleType) {
      return true;
    }

    if (Array.isArray(value)) {
      const arrValue = value as Array<Any>;
      if (arrValue.length === 0) {
        return true;
      }
      if (!(valueType instanceof ArrayType)) {
        return false;
      }
      const elementType = (valueType as ArrayType).getElementType();
      if (elementType instanceof IntType || elementType instanceof DoubleType) {
        return true;
      }
      return false;
    }

    return false;
  }
}
""")

