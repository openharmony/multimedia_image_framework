}

enum Orientation: i32 {
  TOP_LEFT = 1,
  TOP_RIGHT = 2,
  BOTTOM_RIGHT = 3,
  BOTTOM_LEFT = 4,
  LEFT_TOP = 5,
  RIGHT_TOP = 6,
  RIGHT_BOTTOM = 7,
  LEFT_BOTTOM = 8
}

@!sts_inject("""
  const XMAGE_WATERMARK_MODE_AT_THE_BOTTOM: int = 9;
  const XMAGE_WATERMARK_MODE_BORDER: int = 10;
  const CAPTURE_MODE_PROFESSIONAL: int = 2;
  const CAPTURE_MODE_FRONT_LENS_NIGHT_VIEW: int = 7;
  const CAPTURE_MODE_PANORAMA: int = 8;
  const CAPTURE_MODE_TAIL_LIGHT: int = 9;
  const CAPTURE_MODE_LIGHT_GRAFFITI: int = 10;
  const CAPTURE_MODE_SILKY_WATER: int = 11;
  const CAPTURE_MODE_STAR_TRACK: int = 12;
  const CAPTURE_MODE_WIDEAPERTURE: int = 19;
  const CAPTURE_MODE_MOVING_PHOTO: int = 20;
  const CAPTURE_MODE_PORTRAIT: int = 23;
  const CAPTURE_MODE_REAR_LENS_NIGHT_VIEW: int = 42;
  const CAPTURE_MODE_SUPER_MACRO: int = 47;
  const CAPTURE_MODE_SNAP_SHOT: int = 62;
""")

enum FocusMode: i32 {
  AF_A = 0,
  AF_S = 1,
  AF_C = 2,
  MF = 3
}

enum XmageColorMode: i32 {
  NORMAL = 0,
  BRIGHT = 1,
  SOFT = 2,
  MONO = 3
}

enum XMPTagType: i32 {
    UNKNOWN = 0,
    SIMPLE = 1,
    UNORDERED_ARRAY = 2,
    ORDERED_ARRAY = 3,
    ALTERNATE_ARRAY = 4,
    ALTERNATE_TEXT = 5,
    STRUCTURE = 6,
    QUALIFIER = 7
}

struct DecodingOptionsForPicture {
  desiredAuxiliaryPictures: Array<AuxiliaryPictureType>;
}

struct DecodingOptionsForThumbnail {
  maxGeneratedPixelDimension: Optional<i32>;
  generateThumbnailIfAbsent: Optional<bool>;
}

struct AuxiliaryPictureInfo {
  auxiliaryPictureType: AuxiliaryPictureType;
  size: Size;
  rowStride: i32;
  pixelFormat: PixelMapFormat;
  colorSpace: @sts_type("colorSpaceManager.ColorSpaceManager") Opaque;
}

union HdrMetadataValue {
  hdrMetadataType: HdrMetadataType;
  hdrStaticMetadata: HdrStaticMetadata;
  arrayBuffer: @arraybuffer Array<u8>;
  hdrGainmapMetadata: HdrGainmapMetadata;
}

union PropertyValue {
    type_string: String;
    type_null: @null unit;
}

struct ImageReceiverOptions {
  size: Optional<Size>;
  capacity: Optional<i32>;
}

struct ImageBufferData {
  rowStride: Array<i32>;
  pixelStride: Array<i32>;
  byteBuffer: @arraybuffer Array<u8>;
}

union NullableImageBufferData {
  type_imageBufferData: ImageBufferData;
  @null type_null;
