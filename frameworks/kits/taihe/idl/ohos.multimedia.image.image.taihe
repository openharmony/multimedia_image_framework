  @!sts_inject_into_class("""
    delayTime?: int;
  """)
}

struct ImageMetadata {
  exifMetadata: Optional<ExifMetadata>;
  makerNoteHuaweiMetadata: Optional<MakerNoteHuaweiMetadata>;
  heifsMetadata: Optional<HeifsMetadata>;
  dngMetadata: Optional<DngMetadata>;
  webPMetadata: Optional<WebPMetadata>;
  avisMetadata: Optional<AvisMetadata>;
}

