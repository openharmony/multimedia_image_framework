@!namespace("@ohos.multimedia.image", "image")
@!sts_export_default
@!sts_inject("""
static { loadLibraryWithPermissionCheck("image_taihe_core.z", "@ohos.multimedia.image"); }
""")

enum PixelMapFormat: i32 {
  UNKNOWN = 0,
  ARGB_8888 = 1,
  RGB_565 = 2,
  RGBA_8888 = 3,
  BGRA_8888 = 4,
  RGB_888 = 5,
  ALPHA_8 = 6,
  RGBA_F16 = 7,
  NV21 = 8,
  NV12 = 9,
  RGBA_1010102 = 10,
  YCBCR_P010 = 11,
  YCRCB_P010 = 12,
  ALPHA_U8 = 15,
  ASTC_4x4 = 102
}

enum ResolutionQuality: i32 {
  LOW = 1,
  MEDIUM = 2,
  HIGH = 3
}

struct Size {
  width: i32;
  height: i32;
}

