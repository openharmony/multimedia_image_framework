enum ImageFormat: i32 {
  YCBCR_422_SP = 1000,
  JPEG = 2000
}

enum AlphaType: i32 {
  UNKNOWN = 0,
  OPAQUE = 1,
  PREMUL = 2,
  UNPREMUL = 3
}

enum DecodingDynamicRange: i32 {
  AUTO = 0,
  SDR = 1,
  HDR = 2
}

enum PackingDynamicRange: i32 {
  AUTO = 0,
  SDR = 1,
}

enum AntiAliasingLevel: i32 {
  NONE = 0,
  LOW = 1,
  MEDIUM = 2,
  HIGH = 3
}

enum ScaleMode: i32 {
  FIT_TARGET_SIZE = 0,
  CENTER_CROP = 1
}

enum ComponentType: i32 {
  YUV_Y = 1,
  YUV_U = 2,
  YUV_V = 3,
  JPEG = 4
}

enum AllocatorType: i32 {
  AUTO = 0,
  DMA = 1,
  SHARE_MEMORY = 2,
}

struct Region {
  size: Size;
  x: i32;
  y: i32;
}

// Can't use struct because struct is copied instead of referenced, so data changes to "pixels" in C++ will not be reflected in ArkTS
interface PositionArea {
  @get GetPixels(): @arraybuffer Array<u8>;
  @set SetPixels(pixels: @arraybuffer Array<u8>): void;
  @get GetOffset(): i32;
  @set SetOffset(offset: i32): void;
  @get GetStride(): i32;
  @set SetStride(stride: i32): void;
  @get GetRegion(): Region;
  @set SetRegion(region: Region): void;
}

struct ImageInfo {
  size: Size;
  density: i32;
  stride: i32;
  pixelFormat: PixelMapFormat;
  alphaType: AlphaType;
  mimeType: String;
  isHdr: bool;
}

enum CropAndScaleStrategy: i32 {
  SCALE_FIRST = 1,
  CROP_FIRST = 2
}

struct PackingOption {
  format: String;
  quality: i32;
  bufferSize: Optional<i32>;
  desiredDynamicRange: Optional<PackingDynamicRange>;
  needsPackProperties: Optional<bool>;
}

struct PackingOptionsForSequence {
  frameCount: i32;
  delayTimeList: Array<i32>;
  disposalTypes: Optional<Array<i32>>;
  loopCount: Optional<i32>;
}

struct ImagePropertyOptions {
  index: Optional<i32>;
  defaultValue: Optional<String>;
}

struct DecodingOptions {
  index: Optional<i32>;
  sampleSize: Optional<i32>;
  rotate: Optional<i32>;
  editable: Optional<bool>;
  desiredSize: Optional<Size>;
  desiredRegion: Optional<Region>;
  desiredPixelFormat: Optional<PixelMapFormat>;
  photoDesiredPixelFormat: Optional<PixelMapFormat>; // not exposed to the user
  fitDensity: Optional<i32>;
  fillColor: Optional<i32>; // not exposed to the user
  SVGResize: Optional<i32>; // not exposed to the user
  desiredColorSpace: Optional<@sts_type("colorSpaceManager.ColorSpaceManager") Opaque>;
  desiredDynamicRange: Optional<DecodingDynamicRange>;
  resolutionQuality: Optional<ResolutionQuality>;
  cropAndScaleStrategy: Optional<CropAndScaleStrategy>;
  reusePixelmap: Optional<PixelMap>; // not exposed to the user
}

struct Component {
  @readonly componentType: ComponentType;
  @readonly rowStride: i32;
  @readonly pixelStride: i32;
  @readonly byteBuffer: @arraybuffer Array<u8>;
}

struct InitializationOptions {
  size: Size;
  srcPixelFormat: Optional<PixelMapFormat>;
  pixelFormat: Optional<PixelMapFormat>;
  editable: Optional<bool>;
  alphaType: Optional<AlphaType>;
  scaleMode: Optional<ScaleMode>;
}

struct SourceOptions {
  sourceDensity: i32;
  sourcePixelFormat: Optional<PixelMapFormat>;
  sourceSize: Optional<Size>;
}

struct HdrStaticMetadata {
  displayPrimariesX: Array<f64>;
  displayPrimariesY: Array<f64>;
  whitePointX: f64;
  whitePointY: f64;
  maxLuminance: f64;
  minLuminance: f64;
  maxContentLightLevel: f64;
  maxFrameAverageLightLevel: f64;
}

struct GainmapChannel {
  gainmapMax: f64;
  gainmapMin: f64;
  gamma: f64;
  baseOffset: f64;
  alternateOffset: f64;
}

struct HdrGainmapMetadata {
  writerVersion: i32;
  miniVersion: i32;
  gainmapChannelCount: i32;
  useBaseColorFlag: bool;
  baseHeadroom: f64;
  alternateHeadroom: f64;
  channels: Array<GainmapChannel>;
}

enum HdrMetadataKey: i32 {
  HDR_METADATA_TYPE = 0,
  HDR_STATIC_METADATA = 1,
  HDR_DYNAMIC_METADATA = 2,
  HDR_GAINMAP_METADATA = 3,
}

enum HdrMetadataType: i32 {
  NONE = 0,
  BASE = 1,
  GAINMAP = 2,
  ALTERNATE = 3,
}

enum AuxiliaryPictureType: i32 {
  GAINMAP = 1,
  DEPTH_MAP = 2,
  UNREFOCUS_MAP = 3,
  LINEAR_MAP = 4,
  FRAGMENT_MAP = 5,
  THUMBNAIL = 10,
}

enum MetadataType: i32 {
  EXIF_METADATA = 1,
  FRAGMENT_METADATA = 2,
  GIF_METADATA = 5
}

enum FragmentMapPropertyKey: String {
  X_IN_ORIGINAL = "XInOriginal",
  Y_IN_ORIGINAL = "YInOriginal",
  WIDTH = "FragmentImageWidth",
  HEIGHT = "FragmentImageHeight"
}

enum GifPropertyKey: String {
  GIF_DELAY_TIME = "GifDelayTime",
  GIF_DISPOSAL_TYPE = "GifDisposalType"
}

enum XMPTagType: i32 {
    UNKNOWN = 0,
    SIMPLE = 1,
    UNORDERED_ARRAY = 2,
    ORDERED_ARRAY = 3,
    ALTERNATE_ARRAY = 4,
    ALTERNATE_TEXT = 5,
    STRUCTURE = 6,
    QUALIFIER = 7
}

struct DecodingOptionsForPicture {
  desiredAuxiliaryPictures: Array<AuxiliaryPictureType>;
}

struct DecodingOptionsForThumbnail {
  desiredSize: Optional<Size>;
  needGenerate: Optional<bool>;
}

struct AuxiliaryPictureInfo {
  auxiliaryPictureType: AuxiliaryPictureType;
  size: Size;
  rowStride: i32;
  pixelFormat: PixelMapFormat;
  colorSpace: @sts_type("colorSpaceManager.ColorSpaceManager") Opaque;
}

union HdrMetadataValue {
  hdrMetadataType: HdrMetadataType;
  hdrStaticMetadata: HdrStaticMetadata;
  arrayBuffer: @arraybuffer Array<u8>;
  hdrGainmapMetadata: HdrGainmapMetadata;
}

union PropertyValue {
    type_string: String;
    type_null: @null unit;
}

struct ImageReceiverOptions {
  size: Optional<Size>;
  capacity: Optional<i32>;
}

struct ImageBufferData {
  rowStride: Array<i32>;
  pixelStride: Array<i32>;
  byteBuffer: @arraybuffer Array<u8>;
}

union NullableImageBufferData {
  type_imageBufferData: ImageBufferData;
  @null type_null;
}

union NullableHdrMetadataValue {
  type_hdrMetadataValue: HdrMetadataValue;
  @null type_null;
}

interface PixelMap {
  GetImplPtr(): i64;

  @async @rename("getImageInfo")
  GetImageInfoAsync(): ImageInfo;

  @promise @rename("getImageInfo")
  GetImageInfoPromise(): ImageInfo;

  GetImageInfoSync(): ImageInfo;

  @async @rename("readPixelsToBuffer")
  ReadPixelsToBufferAsync(dst: @arraybuffer Array<u8>): void;

  @promise @rename("readPixelsToBuffer")
  ReadPixelsToBufferPromise(dst: @arraybuffer Array<u8>): void;

  ReadPixelsToBufferSync(dst: @arraybuffer Array<u8>): void;

  @async @rename("readPixels")
  ReadPixelsAsync(area: PositionArea): void;

  @promise @rename("readPixels")
  ReadPixelsPromise(area: PositionArea): void;

  ReadPixelsSync(area: PositionArea): void;

  @async @rename("writeBufferToPixels")
  WriteBufferToPixelsAsync(src: @arraybuffer Array<u8>): void;

  @promise @rename("writeBufferToPixels")
  WriteBufferToPixelsPromise(src: @arraybuffer Array<u8>): void;

  WriteBufferToPixelsSync(src: @arraybuffer Array<u8>): void;

  @async @rename("writePixels")
  WritePixelsAsync(area: PositionArea): void;

  @promise @rename("writePixels")
  WritePixelsPromise(area: PositionArea): void;

  WritePixelsSync(area: PositionArea): void;

  @async @rename("createAlphaPixelmap")
  CreateAlphaPixelmapAsync(): PixelMap;

  @promise @rename("createAlphaPixelmap")
  CreateAlphaPixelmapPromise(): PixelMap;

  CreateAlphaPixelmapSync(): PixelMap;

  GetBytesNumberPerRow(): i32;

  GetPixelBytesNumber(): i32;

  GetDensity(): i32;

  @async @rename("scale")
  ScaleAsync(x: f64, y: f64): void;

  @promise @rename("scale")
  ScalePromise(x: f64, y: f64): void;

  ScaleSync(x: f64, y: f64): void;

  @promise @rename("scale")
  ScaleWithAntiAliasingPromise(x: f64, y: f64, level: AntiAliasingLevel): void;

  @rename("scaleSync")
  ScaleWithAntiAliasingSync(x: f64, y: f64, level: AntiAliasingLevel): void;

  @promise @rename("createCroppedAndScaledPixelMap")
  CreateCroppedAndScaledPixelMapPromise(region: Region, x: f64, y: f64, level: Optional<AntiAliasingLevel>): PixelMap;

  CreateCroppedAndScaledPixelMapSync(region: Region, x: f64, y: f64, level: Optional<AntiAliasingLevel>): PixelMap;

  @promise @rename("createScaledPixelMap")
  CreateScaledPixelMapPromise(x: f64, y: f64, level: Optional<AntiAliasingLevel>): PixelMap;

  CreateScaledPixelMapSync(x: f64, y: f64, level: Optional<AntiAliasingLevel>): PixelMap;

  @promise @rename("clone")
  ClonePromise(): PixelMap;

  CloneSync(): PixelMap;

  @async @rename("translate")
  TranslateAsync(x: f64, y: f64): void;

  @promise @rename("translate")
  TranslatePromise(x: f64, y: f64): void;

  TranslateSync(x: f64, y: f64): void;

  @async @rename("crop")
  CropAsync(region: Region): void;

  @promise @rename("crop")
  CropPromise(region: Region): void;

  CropSync(region: Region): void;

  @async @rename("rotate")
  RotateAsync(angle: f64): void;

  @promise @rename("rotate")
  RotatePromise(angle: f64): void;

  RotateSync(angle: f64): void;

  @async @rename("flip")
  FlipAsync(horizontal: bool, vertical: bool): void;

  @promise @rename("flip")
  FlipPromise(horizontal: bool, vertical: bool): void;

  FlipSync(horizontal: bool, vertical: bool): void;

  @async @rename("opacity")
  OpacityAsync(rate: f64): void;

  @promise @rename("opacity")
  OpacityPromise(rate: f64): void;

  OpacitySync(rate: f64): void;

  @promise @rename("toSdr")
  ToSdrPromise(): void;

  ToSdrSync(): void;

  @async @rename("applyColorSpace")
  ApplyColorSpaceAsync(targetColorSpace: @sts_type("colorSpaceManager.ColorSpaceManager") Opaque): void;

  @promise @rename("applyColorSpace")
  ApplyColorSpacePromise(targetColorSpace: @sts_type("colorSpaceManager.ColorSpaceManager") Opaque): void;

  ApplyColorSpaceSync(targetColorSpace: @sts_type("colorSpaceManager.ColorSpaceManager") Opaque): void;

  SetMemoryNameSync(name: String): void;

  SetTransferDetached(detached: bool): void;

  @promise @rename("convertPixelFormat")
  ConvertPixelFormatPromise(targetPixelFormat: PixelMapFormat): void;

  ConvertPixelFormatSync(targetPixelFormat: PixelMapFormat): void;

  GetColorSpace(): @sts_type("colorSpaceManager.ColorSpaceManager") Opaque;

  SetColorSpace(colorSpace: @sts_type("colorSpaceManager.ColorSpaceManager") Opaque): void;

  Marshalling(sequence: @sts_type("rpc.MessageSequence") Opaque): void;

  @promise @rename("unmarshalling")
  UnmarshallingPromise(sequence: @sts_type("rpc.MessageSequence") Opaque): PixelMap;

  UnmarshallingSync(sequence: @sts_type("rpc.MessageSequence") Opaque): PixelMap;

  GetMetadata(key: HdrMetadataKey): HdrMetadataValue;

  @promise @rename("setMetadata")
  SetMetadataPromise(key: HdrMetadataKey, value: HdrMetadataValue): void;

  SetMetadataSync(key: HdrMetadataKey, value: HdrMetadataValue): void;

  @async @rename("release")
  ReleaseAsync(): void;

  @promise @rename("release")
  ReleasePromise(): void;

  ReleaseSync(): void;

  IsReleased(): bool;

  GetUniqueId(): i32;

  @get GetIsEditable(): bool;

  @get GetIsStrideAlignment(): bool;

  @set SetCaptureId(captureId: i32): void;
  @get GetCaptureId(): i32;

  @set SetTimestamp(timestamp: i64): void;
  @get GetTimestamp(): i64;
}

union NullablePixelMap {
    type_pixelMap: PixelMap;
    type_null: @null unit;
}

union AuxPicture {
    type_auxPicture: AuxiliaryPicture;
    type_null: @null unit;
}

struct HdrComposeOptions {
  desiredPixelFormat: Optional<PixelMapFormat>;
}

interface Picture {
  GetImplPtr(): i64;

  GetMainPixelmap(): Optional<PixelMap>;

  @promise @rename("getHdrComposedPixelmap")
  GetHdrComposedPixelmapSync(): Optional<PixelMap>;

  @promise @rename("getHdrComposedPixelmapWithOptions")
  GetHdrComposedPixelmapWithOptionsSync(options: Optional<HdrComposeOptions>): Optional<PixelMap>;

  GetGainmapPixelmap(): NullablePixelMap;

  GetThumbnailPixelmap(): NullablePixelMap;

  SetThumbnailPixelmap(thumbnailPixelmap: PixelMap): void;

  SetAuxiliaryPicture(type: AuxiliaryPictureType, auxiliaryPicture: AuxiliaryPicture): void;

  GetAuxiliaryPicture(type: AuxiliaryPictureType): AuxPicture;

  DropAuxiliaryPicture(type: AuxiliaryPictureType): void;

  @promise @rename("setMetadata")
  SetMetadataSync(metadataType: MetadataType, metadata: Metadata): void;

  @promise @rename("getMetadata")
  GetMetadataSync(metadataType: MetadataType): Optional<Metadata>;

  Marshalling(sequence: @sts_type("rpc.MessageSequence") Opaque): void;

  Release(): void;
}

interface AuxiliaryPicture {
  GetImplPtr(): i64;

  @promise @rename("writePixelsFromBuffer")
  WritePixelsFromBufferSync(data: @arraybuffer Array<u8>): void;

  @promise @rename("readPixelsToBuffer")
  ReadPixelsToBufferSync(): Optional<@arraybuffer Array<u8>>;

  GetType(): Optional<AuxiliaryPictureType>;

  @promise @rename("setMetadata")
